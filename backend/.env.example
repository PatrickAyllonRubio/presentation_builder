# Copiar este archivo a .env y rellenar los valores

# Desarrollo (SQLite)
DATABASE_URL=sqlite:///./cerv_courses.db
# Producción (Neon PostgreSQL) — pegar la connection string de Neon
# DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

STORAGE_PATH=./storage
GOOGLE_TTS_API_KEY=tu_api_key_aqui
DEBUG=True

# CORS: orígenes permitidos separados por coma (producción)
# CORS_ORIGINS=https://tu-app.vercel.app,http://localhost:5173
